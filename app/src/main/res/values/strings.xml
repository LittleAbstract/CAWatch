    <string name="detail_accepted">Added to baseline</string>
    <string name="detail_dismissed">Removed from history</string>

    <!-- Dialogs -->
    <string name="dialog_reset_title">Reset trusted baseline?</string>
    <string name="dialog_reset_body">This clears your baseline and detection history, then captures a new baseline from CAs currently on the device. Any malicious CA already present will be treated as trusted.</string>
    <string name="dialog_clear_title">Clear detection history?</string>
    <string name="dialog_clear_body">Detected events will be removed. The trusted baseline is kept.</string>
    <string name="dialog_confirm">Confirm</string>
    <string name="dialog_cancel">Cancel</string>

