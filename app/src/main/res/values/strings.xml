    <!-- Onboarding -->
    <string name="onboarding_title">Know when a CA is installed</string>
    <string name="onboarding_body">A user Certificate Authority can let someone intercept HTTPS traffic on this device.\n\nCAWatch snapshots your current user CAs, then alerts you the moment a new one appears. Everything stays on your phone — no network, no accounts.</string>
    <string name="onboarding_mode_title">How should we monitor?</string>
    <string name="onboarding_mode_boot_label">Boot + manual (recommended)</string>
    <string name="onboarding_mode_boot_desc">Scans after reboot and when you tap Scan. No persistent notification.</string>
    <string name="onboarding_mode_always_label">Always-on</string>
    <string name="onboarding_mode_always_desc">Keeps a foreground service running for continuous monitoring. Shows a status notification.</string>
    <string name="onboarding_privacy">Reads only certificate issuer, subject, and SHA-256 fingerprint. Stores data locally. Never leaves the device.</string>
    <string name="onboarding_continue">Continue</string>
    <string name="onboarding_get_started">Capture baseline &amp; start</string>
    <string name="onboarding_notifications_hint">Allow notifications so you can be alerted immediately when a new CA is installed.</string>

