    <string name="detail_issuer">Issuer</string>
    <string name="detail_subject">Subject</string>
    <string name="detail_fingerprint">SHA-256 fingerprint</string>
    <string name="detail_detected_at">Detected</string>
    <string name="detail_explain">This certificate was not in your trusted baseline. Malware, VPN apps, MDM profiles, or tools like Charles/mitmproxy sometimes install user CAs. If you did not install it, remove it in system settings.</string>
